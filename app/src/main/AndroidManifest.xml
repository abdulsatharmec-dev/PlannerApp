<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <!-- Special: user must grant in system Settings → Usage access -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Resolve app labels/icons for usage list (launcher apps + full inventory for stats). -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- Package visibility (Android 11+): Google Sign-In / Play services -->
    <queries>
        <package android:name="com.google.android.gms" />
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:name=".DailyCuratorApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DailyCurator">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.DailyCurator"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".pomodoro.PomodoroForegroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            tools:targetApi="34">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Pomodoro focus timer"
                tools:targetApi="34" />
        </service>

        <receiver
            android:name=".pomodoro.PomodoroActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.dailycurator.pomodoro.PAUSE" />
                <action android:name="com.dailycurator.pomodoro.RESUME" />
                <action android:name="com.dailycurator.pomodoro.STOP" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".reminders.DayRouteReminderReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.dailycurator.reminder.TASK_ALARM" />
                <action android:name="com.dailycurator.reminder.TASK_DONE" />
                <action android:name="com.dailycurator.reminder.TASK_POMODORO" />
                <action android:name="com.dailycurator.reminder.TASK_DISMISS" />
                <action android:name="com.dailycurator.reminder.HABIT_ALARM" />
                <action android:name="com.dailycurator.reminder.HABIT_OPEN" />
                <action android:name="com.dailycurator.reminder.HABIT_DISMISS" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".reminders.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
